	<Binding name="PRAT_NEXTTAB" header="Prat">
		local mod = Prat:GetModule("KeyBindings")
		if mod then
			mod:CycleChatTabs()
		end
	</Binding>
	<!-- TellTarget -->
	<Binding name="PRAT_TELLTARGET" header="Prat">
		local mod = Prat:GetModule("TellTarget")
		if mod then
			mod:SendTellToTarget(SELECTED_CHAT_FRAME, "");
		end
	</Binding>
	<!-- CopyChat -->
	<Binding name="PRAT_COPYSELECTED" header="Prat">
		local mod = Prat:GetModule("CopyChat")
		if mod then
			mod:CopyChat();
		end
	</Binding>
	<Binding name="PRAT_SCROLLBOTTOM" header="Prat">
		SELECTED_CHAT_FRAME:ScrollToBottom()
	</Binding>
	<Binding name="PRAT_SCROLLTOP" header="Prat">
		SELECTED_CHAT_FRAME:ScrollToTop()
	</Binding>
</Bindings>
